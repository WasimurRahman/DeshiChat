MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster-url>/whatsapp-clone?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=your_jwt_secret_key_here_change_in_production
NODE_ENV=development
EMAIL_USER=your_primary_smtp_username
EMAIL_PASS=your_primary_smtp_password
EMAIL_FROM=your_sender_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_TIMEOUT_MS=12000
SMTP_RETRIES=1
# Recommended on Render: use Brevo HTTP API to avoid SMTP network timeouts
BREVO_API_KEY=
BREVO_API_RETRIES=1
EMAIL_TEST_SECRET=replace_with_random_long_secret
# Optional fallback SMTP provider (example: Brevo free SMTP)
SMTP_FALLBACK_HOST=
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
